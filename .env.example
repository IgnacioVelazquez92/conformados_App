DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Use `config.settings.development` locally and `config.settings.railway` on Railway.
DJANGO_SETTINGS_MODULE=config.settings.development

SQLITE_PATH=

DB_NAME=conformados
